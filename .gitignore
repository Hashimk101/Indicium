# --- IntelliJ IDEA ---
.idea/**
# Explicitly un-ignore the "soul" of the project structure
!.idea/modules.xml
!.idea/compiler.xml
!.idea/misc.xml
!.idea/vcs.xml

# Ignore all other IDE metadata/temp files (fixes the Copilot/Agent XML issue)
.idea/*.xml
.idea/libraries/
.idea/shelf/
.idea/workspace.xml
*.iml
*.iws
*.ipr

# --- Build & Output ---
out/
target/
build/
bin/

# --- OS Specific ---
.DS_Store
Thumbs.db
desktop.ini

# --- Indicium Specific (Database & Logs) ---
*.db
*.sql
*.log
/evidence_storage/
config.properties
